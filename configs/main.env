#!/usr/bin/env bash
# =============================================================================
# main.env — Single Configuration File for the Entire OpenStack Project (v3)
# =============================================================================
# Edit this file ONCE before running anything, or run the Setup Wizard:
#   sudo bash deploy.sh --wizard
#
# Every script in this project sources this file.
#
# ⚠  SECURITY: Add these lines to .gitignore before committing:
#       configs/main.env
#       configs/.secrets.env
#       configs/.secrets.enc
#
# ⚠  DISTRO: Works on any Debian-based distro with systemd + apt + kernel 5.4+
#       Tested: Ubuntu 20.04 / 22.04 / 24.04, Debian 11 / 12, Linux Mint 21+
# =============================================================================

# ─── CONFIG SCHEMA VERSION (do not remove) ────────────────────────────────────
CONFIG_VERSION="3.0"

# ─── DISTRO & HARDWARE (set automatically by Setup Wizard) ────────────────────
# These are written by detect_distro() / detect_hardware_type() in lib.sh.
# You can override manually if needed.
DISTRO_FAMILY="debian"             # debian | unknown
HARDWARE_TYPE="unknown"            # physical | vm | container | unknown

# ─── DEPLOYMENT MODE ──────────────────────────────────────────────────────────
# all-in-one  → everything on a single machine (default, easiest)
# multi-node  → controller + separate compute + storage nodes
DEPLOY_MODE="all-in-one"

# ─── NODE IPs ─────────────────────────────────────────────────────────────────
# HOST_IP is __CHANGE_ME__ by default. The Setup Wizard (or you) must set a
# real value before any deployment will proceed.
#
# For all-in-one: only HOST_IP matters.
# For multi-node: set all four.
HOST_IP="__CHANGE_ME__"           # This machine's IP (run: hostname -I)
CONTROLLER_IP="__CHANGE_ME__"     # Controller node IP
STORAGE_IP="10.0.0.30"            # Storage node IP

# COMPUTE_IPS — space-separated string (bash arrays cannot be exported).
# In any script that needs them as an array:
#   read -ra COMPUTE_IPS <<< "${COMPUTE_IPS_STR}"
COMPUTE_IPS_STR="10.0.0.20"       # Add more: "10.0.0.20 10.0.0.21 10.0.0.22"

# ─── NETWORK INTERFACES ───────────────────────────────────────────────────────
INTERFACE_NAME="ens3"              # Primary NIC (run: ip link show)
CONTROLLER_IFACE="ens3"
COMPUTE_IFACE="ens3"
STORAGE_IFACE="ens3"

# ─── PASSWORDS ────────────────────────────────────────────────────────────────
# RECOMMENDED: Keep passwords in a separate secrets file that is never committed.
#
#   1. Copy this block to  configs/.secrets.env
#   2. Add configs/.secrets.env to .gitignore
#   3. Set the passwords there instead of here
#   4. Optionally encrypt it:
#        openssl enc -aes-256-cbc -pbkdf2 -in configs/.secrets.env \
#                                             -out configs/.secrets.enc
#
# lib.sh will auto-load configs/.secrets.env (or .secrets.enc) when present,
# overriding the placeholder values below.
#
# Rules: avoid special chars @ # $ & in passwords; 16+ chars recommended.
ADMIN_PASS="REPLACE_WITH_STRONG_PASSWORD"
DB_PASS="REPLACE_WITH_STRONG_PASSWORD"
RABBIT_PASS="REPLACE_WITH_STRONG_PASSWORD"
SERVICE_PASS="REPLACE_WITH_STRONG_PASSWORD"

# ─── OPENSTACK SETTINGS ───────────────────────────────────────────────────────
REGION_NAME="RegionOne"
CONTROLLER="controller"
OS_RELEASE="caracal"               # OpenStack 2024.1 (Ubuntu 24.04 default)

# ─── EXTRA SERVICES TO INSTALL ────────────────────────────────────────────────
# Set to "true" to include a service in the full deployment.
INSTALL_CINDER="true"              # Block Storage  (like AWS EBS)
INSTALL_SWIFT="true"               # Object Storage (like AWS S3)
INSTALL_HEAT="true"                # Orchestration  (like CloudFormation)
INSTALL_CEILOMETER="false"         # Telemetry — resource-heavy, off by default
INSTALL_BARBICAN="true"            # Secrets Manager (like HashiCorp Vault)
INSTALL_OCTAVIA="false"            # Load Balancer — needs Amphora image
INSTALL_MANILA="false"             # Shared Filesystems (like AWS EFS)
INSTALL_DESIGNATE="true"           # DNS as a Service (like Route 53)

# ─── KEYSTONE SERVICE CATALOG ─────────────────────────────────────────────────
# Space-separated list of services to register in Keystone's service catalog.
# "keystone glance placement" are always registered regardless of this setting.
# The Setup Wizard (Step 5) writes this from your endpoint selections.
# Available tokens: nova neutron cinder swift heat barbican designate octavia manila ceilometer
KEYSTONE_SERVICES_STR="keystone glance placement nova neutron"

# ─── KUBERNETES ───────────────────────────────────────────────────────────────
K8S_WORKER_COUNT=2
K8S_KEYPAIR_NAME="k8s-key"
K8S_EXTERNAL_NETWORK="public"      # Name of your OpenStack external network
K8S_POD_CIDR="10.244.0.0/16"

# ─── SSL / LET'S ENCRYPT ──────────────────────────────────────────────────────
ACME_EMAIL="admin@yourdomain.com"
OPENSTACK_DOMAIN="cloud.yourdomain.com"
DEPLOY_TO_BARBICAN="false"

# ─── BACKUP & DISASTER RECOVERY ───────────────────────────────────────────────
BACKUP_PATH="/var/backups/openstack"
BACKUP_KEEP_DAYS=7
SWIFT_BACKUP_ENABLED="false"
SWIFT_BACKUP_CONTAINER="openstack-backups"

# ─── LOG RETENTION ────────────────────────────────────────────────────────────
# Deployment logs older than this many days are automatically pruned.
LOG_KEEP_DAYS=30

# ─── MONITORING & ALERTS ──────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=""               # Paste your Slack webhook URL here
ALERT_EMAIL=""                     # Email address for downtime alerts
MONITOR_INTERVAL=30                # Dashboard refresh interval (seconds)

# SMTP — used by monitor.sh to send email alerts.
# Leave blank to disable email alerting.
SMTP_HOST=""                       # e.g. smtp.yourcompany.com
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""                       # Consider putting this in .secrets.env instead

# ─── SERVER HARDENING ─────────────────────────────────────────────────────────
HARDENING_AUDIT_ONLY="false"       # true = check only, false = fix + check

# ─── DERIVED VARIABLES (do not edit below this line) ──────────────────────────
export HOST_IP CONTROLLER_IP STORAGE_IP COMPUTE_IPS_STR
export INTERFACE_NAME CONTROLLER_IFACE COMPUTE_IFACE STORAGE_IFACE
export ADMIN_PASS DB_PASS RABBIT_PASS SERVICE_PASS
export REGION_NAME CONTROLLER OS_RELEASE DEPLOY_MODE
export DISTRO_FAMILY HARDWARE_TYPE
export KEYSTONE_SERVICES_STR
export INSTALL_CINDER INSTALL_SWIFT INSTALL_HEAT INSTALL_CEILOMETER
export INSTALL_BARBICAN INSTALL_OCTAVIA INSTALL_MANILA INSTALL_DESIGNATE
export K8S_WORKER_COUNT K8S_KEYPAIR_NAME K8S_EXTERNAL_NETWORK K8S_POD_CIDR
export ACME_EMAIL OPENSTACK_DOMAIN DEPLOY_TO_BARBICAN
export BACKUP_PATH BACKUP_KEEP_DAYS SWIFT_BACKUP_ENABLED SWIFT_BACKUP_CONTAINER
export LOG_KEEP_DAYS
export SLACK_WEBHOOK_URL ALERT_EMAIL MONITOR_INTERVAL
export SMTP_HOST SMTP_PORT SMTP_USER SMTP_PASS
export HARDENING_AUDIT_ONLY
export CONFIG_VERSION

# OpenStack CLI auth (loaded automatically for all scripts)
export OS_USERNAME=admin
export OS_PASSWORD="${ADMIN_PASS}"
export OS_PROJECT_NAME=admin
export OS_USER_DOMAIN_NAME=Default
export OS_PROJECT_DOMAIN_NAME=Default
export OS_AUTH_URL="http://${HOST_IP}:5000/v3"
export OS_IDENTITY_API_VERSION=3
export OS_IMAGE_API_VERSION=2
